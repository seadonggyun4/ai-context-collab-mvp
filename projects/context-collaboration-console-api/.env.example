APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql://context_console:context_console@127.0.0.1:5432/context_console
CORS_ALLOWED_ORIGINS=http://localhost:5173
DOCUMENT_REPOSITORY=../..
DOCUMENT_BRANCH=HEAD
DOCUMENT_MAX_BYTES=1048576
FRONTEND_ORIGINS=http://localhost:5173
SESSION_COOKIE_NAME=context_console_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=28800
RATE_LIMIT_READ_PER_MINUTE=120
RATE_LIMIT_MUTATION_PER_MINUTE=30
# Production-only values are injected as Render secrets/references:
# SECURITY_STORE_URL=redis://127.0.0.1:6379/0
# OIDC_ISSUER=https://identity.example.com
# OIDC_CLIENT_ID=context-console
# OIDC_CLIENT_SECRET=<secret-manager-value>
# OIDC_CALLBACK_URL=https://api.example.com/api/v1/auth/callback
# OIDC_ROLE_MAPPING={"context-viewers":"viewer","context-reviewers":"reviewer","context-admins":"admin"}
